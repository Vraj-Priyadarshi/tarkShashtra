      ],
      "response": [
        {
          "name": "400 Bad Request — Invalid token",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n    \"timestamp\": \"2026-04-18T10:00:00\",\n    \"status\": 400,\n    \"error\": \"Bad Request\",\n    \"message\": \"Invalid or expired token\",\n    \"path\": \"/api/auth/validate-reset-token\"\n}"
        }
      ]
    },
