    {
      "name": "18. Login After Password Reset (mustChangePassword = false)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"coordinator@pdeu.ac.in\",\n    \"password\": \"Reset@PDEU2026!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "description": "Login with the new password set via reset flow. mustChangePassword should be false — full access granted immediately."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('mustChangePassword is FALSE after reset', function () {",
              "    pm.expect(pm.response.json().mustChangePassword).to.be.false;",
              "});",
              "",
              "pm.test('New token saved', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
              "    pm.collectionVariables.set('accessToken', body.accessToken);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "response": [
        {
          "name": "200 OK — Full access",
          "status": "OK",
          "code": 200,
          "body": "{\n    \"accessToken\": \"eyJhbGciOiJIUzUxMiJ9...\",\n    \"tokenType\": \"Bearer\",\n    \"userId\": \"uuid-here\",\n    \"email\": \"coordinator@pdeu.ac.in\",\n    \"roles\": [\"ACADEMIC_COORDINATOR\"],\n    \"instituteId\": \"uuid-here\",\n    \"mustChangePassword\": false\n}"
        }
      ]
    },
    {
      "name": "19. Re-use Reset Token (expect 400 — single use)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"token\": \"{{resetToken}}\",\n    \"newPassword\": \"AnotherNew@2026!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/reset-password",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "reset-password"]
        },
        "description": "Negative test — token was already used in request #16. Should return 400 (token already used)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 400 — token already used', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "response": [
        {
          "name": "400 Bad Request — Token already used",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n    \"timestamp\": \"2026-04-18T10:00:00\",\n    \"status\": 400,\n    \"error\": \"Bad Request\",\n    \"message\": \"Token has already been used\",\n    \"path\": \"/api/auth/reset-password\"\n}"
        }
      ]
    }
  ]
}
